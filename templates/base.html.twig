<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        
    </head>
    <body>
        {% block body %}
            <div class="d-flex">
                <!-- Sidebar -->
                {% include "menu.html.twig" with {'item':0} %}

                <!-- Contenido principal -->
                <div class="p-4" style="flex-grow: 1;">
                    {% block cuerpo %}
                        
                    {% endblock %}
                </div>
            </div>
        {% endblock %}
        {% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

            {{ encore_entry_script_tags('app') }}
            {% block importmap %}
                {{ importmap('app') }}
            {% endblock %}
        {% endblock %}
    </body>
</html>

<div class="d-flex flex-column flex-shrink-0 p-3 text-bg-dark min-vh-100" style="width: 250px; ">
    <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
        <span class="fs-4">LICENCIAS DE FUNCIONAMIENTO</span>
        
    </a>
    <hr>
    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <a href="{{path('app_home')}}" class="nav-link {{ (item|default(0)) == 0 ? 'active' : '' }} text-white" aria-current="page">
                <i class="bi bi-house"></i> Inicio
            </a>
        </li>
        {% if is_granted('ROLE_ADMIN') %}
            <li>
                <a href="{{ path('negocio_nuevo') }}" class="nav-link {{ item==1 ? 'active' }} text-white">
                    <i class="bi bi-speedometer2"></i> Nuevo
                </a>
            </li>
        {% endif %}
            
        <li>
            <a href="#" class="nav-link text-white">
                <i class="bi bi-bag"></i> Reportes
            </a>
        </li>
    </ul>
    <hr>
    <div class="dropdown">
        <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="/img/logo_informe.png" alt="" width="32" height="32" class="rounded-circle me-2">
            <strong>{{app.user.nombre|default('') }}</strong>
        </a>
        <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
            <li><a class="dropdown-item" href="#">Perfil</a></li>

            {% if is_granted('ROLE_SUPER_ADMIN') %}
            <li><a class="dropdown-item" href="{{path('app_register')}}">Registrar Nuevo</a></li>
            {% endif %}
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{{path('app_logout')}}">Cerrar sesión</a></li>
        </ul>
    </div>
</div>
{% extends 'base.html.twig' %}
{% block title %}
    ADMINISTRACIÓN TRIBUTARIA
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {# base.html.twig #}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
        <script>
        $(document).ready(function() {
            $('#usuarios').DataTable({
            language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' }, pageLength: 10, responsive: true });
        });

    </script>
    {% endblock %}
    {% block body %}
        <div class="d-flex">
            <!-- Sidebar -->
            {% include "menu.html.twig" with {'item':0} %}
            <div class="p-4" style="flex-grow: 1;">
                {% block cuerpo %}
                    <h1>
                        {{ sede.nombrenegocio }}
                    </h1>
                    <h6 class="text-secondary">
                        {{ sede.negocio.ruc }}
                    </h6>
                    <h6 class="text-secondary">
                        {{ sede.negocio.razonsocial }}
                    </h6>
                    <h6 class="text-secondary">
                        {{ sede.negocio.giro.actividad }}
                    </h6>
                    <hr>
                        <p>
                            Direccion:
                            <strong>
                                {{ sede.via ?? '' }}
                                {{ sede.direccion }}
                                -
                                {{ sede.distrito.nombre }}
                                -
                                {{ sede.provincia.nombre }}
                                -
                                {{ sede.departamento.nombre }}
                            </strong>
                        </p>
                        <p>
                            Celular:
                            <strong>
                                {{ sede.celular }}
                            </strong>
                        </p>
                        <p>
                            Area:
                            <strong>
                                {{ sede.area ?? '0' }}
                                M2
                            </strong>
                        </p>
                        <p>
                            Horario:
                            <strong>
                                {{ sede.horario }}
                            </strong>
                        </p>
                        <h5>
                            Se encontraron
                            {{ licencias|length }}
                            licencias
                        </h5>
                        {% set vigente=0 %}
                        <div class="accordion accordion-flush" id="accordionFlushExample">
                            {% for lic in licencias %}
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapse-{{ lic.id }}" aria-expanded="false" aria-controls="flush-collapseOne">
                                            Nro. Licencia
                                            {{ lic.numero ?? '' }}
                                        </button>
                                    </h2>
                                    <div id="flush-collapse-{{ lic.id }}" class="accordion-collapse collapse" data-bs-parent="#accordionFlushExample">
                                        <div class="accordion-body">
                                            <p>
                                                Nro. Resolución:
                                                {{ lic.resolucion }}
                                            </p>
                                            <p>
                                                Expediente:
                                                {{ lic.expediente }}
                                            </p>
                                            <p>
                                                Días:
                                                {{ lic.dias }}
                                            </p>
                                            <p>
                                                Inicio:
                                                {{ lic.inicio|date('d-m-Y') }}
                                            </p>
                                            <p>
                                                Fin:
                                                {{ lic.fin|date('d-m-Y') }}
                                            </p>
                                            {% if lic.fin > date('now') %}
                                                <p>
                                                    Estado:
                                                    <strong>
                                                        {{ lic.estado == 0 ? 'Sin Firmar' : 'Vigente' }}
                                                    </strong>
                                                    <!-- and is_granted('ROLE_ADMIN')-->
                                                    {% if lic.estado == 0 %}
                                                        <form action="{{ path('subir_pdfs', { id: lic.id }) }}" method="post" enctype="multipart/form-data">
                                                            <label for="archivo">
                                                                Selecciona PDF:
                                                            </label>
                                                            <input type="file" name="archivo" id="archivo" accept="application/pdf" required>
                                                                <button type="submit" class="btn btn-success">
                                                                    Subir
                                                                </button>
                                                            </form>
                                                        {% else %}
                                                            <a href="/pdfs/{{ lic.urllicencia ?? '#' }}" target="_blanck">
                                                                ver Licencia
                                                            </a>
                                                            {% set vigente = 1 %}
                                                        {% endif %}
                                                    </p>
                                                {% else %}
                                                    <p>
                                                        Estado:
                                                        <strong>
                                                            Vencido
                                                        </strong>
                                                    </p>
                                                    <a href="{{ lic.urllicencia ?? '#' }}" target="_blanck">
                                                        ver Licencia
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    
                                {% endfor %}
                                <br>
                                <a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalLicencia">
                                    Agregar Licencia
                                </a>
                            </div>
                            <div class="modal fade" id="modalLicencia" tabindex="-1" aria-labelledby="modalLicenciaLabel" aria-hidden="true">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalLicenciaLabel">
                                                Nueva Licencia
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                                        </div>
                                        <div class="modal-body">
                                            <form action="{{ path('agregar_licencia', { id: sede.id }) }}" method="post" enctype="multipart/form-data">
                                                <div class="row">
                                                    <div class="col-sm-6 col-12 mb-3">
                                                        <label class="form-label">
                                                            Tipo de Licencia
                                                        </label>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio" name="tipo-licencia" id="radioTemp" value="0">
                                                                <label class="form-check-label" for="radioTemp">
                                                                    Licencia temporal
                                                                </label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="tipo-licencia" id="radioDef" value="1" checked>
                                                                    <label class="form-check-label" for="radioDef">
                                                                        Licencia definitiva
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <div class="col-sm-6 col-12 mb-3">
                                                                <label for="resolucion-licencia" class="form-label">
                                                                    Resolución
                                                                </label>
                                                                <input type="text" class="form-control" id="resolucion-licencia" name="resolucion-licencia" required></div>
                                                                <div class="col-sm-6 col-12 mb-3">
                                                                    <label for="expediente-licencia" class="form-label">
                                                                        Nro. expediente
                                                                    </label>
                                                                    <input type="text" class="form-control" id="expediente-licencia" name="expediente-licencia" required></div>
                                                                    <div class="col-sm-6 col-12 mb-3">
                                                                        <label for="numero-licencia" class="form-label">
                                                                            Nro. Licencia
                                                                        </label>
                                                                        <input type="text" class="form-control" id="numero-licencia" name="numero-licencia" required></div>
                                                                        <div class="col-sm-6 col-12 mb-3">
                                                                            <label for="dias-licencia" class="form-label">
                                                                                Días
                                                                            </label>
                                                                            <input type="number" class="form-control" id="dias-licencia" name="dias-licencia" required></div>
                                                                            <div class="col-sm-6 col-12 mb-3">
                                                                                <label for="ini-licencia" class="form-label">
                                                                                    Fecha Inicio
                                                                                </label>
                                                                                <input type="date" class="form-control" id="ini-licencia" name="ini-licencia" required></div>
                                                                                <div class="col-sm-6 col-12 mb-3">
                                                                                    <label for="fin-licencia" class="form-label">
                                                                                        Fecha Fin
                                                                                    </label>
                                                                                    <input type="date" class="form-control" id="fin-licencia" name="fin-licencia"></div>
                                                                                </div>
                                                                                <div class="modal-footer">
                                                                                    <button type="submit" class="btn btn-success">
                                                                                        Guardar Licencia
                                                                                    </button>
                                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                                                        Cancelar
                                                                                    </button>
                                                                                </div>
                                                                            </form>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        {% endblock %}
                                                    </div>
                                                </div>
                                            {% endblock %}
                                            